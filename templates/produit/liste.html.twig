{% extends 'base.html.twig' %}

{% block title %}Liste des Produits{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2 class="mb-0">Liste des Produits</h2>
                <div>
                    <a href="{{ path('app_boutique') }}" class="btn btn-primary me-2">
                        <i class="bi bi-shop"></i> Boutique
                    </a>
                    <a href="{{ path('ajouter_produit') }}" class="btn btn-success me-2">
                        <i class="bi bi-plus-circle"></i> Nouveau Produit
                    </a>
                    <a href="{{ path('app_dashboard') }}" class="btn btn-info">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nom</th>
                                <th>Description</th>
                                <th>Prix</th>
                                <th>Quantité</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for produit in produits %}
                                <tr>
                                    <td>{{ produit.id }}</td>
                                    <td>{{ produit.nom }}</td>
                                    <td>{{ produit.description|slice(0, 50) ~ '...' }}</td>
                                    <td>{{ produit.prix|number_format(2, ',', ' ') }} €</td>
                                    <td>{{ produit.quantite }}</td>
                                    <td class="text-end">
                                        <div class="btn-group" role="group">
                                            <a href="{{ path('supprimer_produit', {'id': produit.id}) }}" 
                                               class="btn btn-sm btn-outline-danger"
                                               data-bs-toggle="tooltip"
                                               title="Supprimer"
                                               onclick="return confirm('Êtes-vous sûr de vouloir supprimer ce produit ?')">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="text-center py-4">
                                        <div class="text-muted">
                                            <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                            <p class="mt-2 mb-0">Aucun produit trouvé</p>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %} 