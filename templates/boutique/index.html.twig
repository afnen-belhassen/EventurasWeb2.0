{% extends 'base.html.twig' %}

{% block title %}Boutique{% endblock %}

{% block body %}
    <main>
        <header class="site-header">
            <div class="container">
                <div class="row">
                    <div class="col-lg-12 col-12 d-flex flex-wrap">
                        <p class="d-flex me-4 mb-0">
                            <i class="bi-shop custom-icon me-2"></i>
                            <strong class="text-dark">Notre Boutique</strong>
                        </p>
                    </div>
                </div>
            </div>
        </header>

        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_boutique') }}">
                    Eventuras Shop
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav align-items-lg-center ms-auto me-lg-5">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_boutique') }}">Accueil</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#produits">Produits</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#contact">Contact</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <section class="boutique-section section-padding" id="produits">
            <div class="container">
                <div class="row">
                    <div class="col-12">
                        <div class="section-title-wrap mb-5">
                            <h2 class="text-white">Nos Produits</h2>
                        </div>
                    </div>
                </div>

                <div class="row">
                    {% for produit in produits %}
                        <div class="col-lg-4 col-md-6 col-12 mb-4">
                            <div class="custom-block custom-block-bg">
                                <div class="custom-block-image-wrap">
                                    <img src="{{ asset('images/produits/' ~ produit.nom|lower ~ '.jpg') }}" 
                                         class="custom-block-image img-fluid" 
                                         alt="{{ produit.nom }}"
                                         onerror="this.src='{{ asset('images/produits/default.jpg') }}'">
                                </div>

                                <div class="custom-block-info">
                                    <h5 class="text-white mb-2">{{ produit.nom }}</h5>
                                    <p class="text-white mb-0">{{ produit.description }}</p>
                                    
                                    <div class="d-flex justify-content-between align-items-center mt-3">
                                        <span class="text-white fw-bold">{{ produit.prix }} TND</span>
                                        <span class="text-white">
                                            <i class="bi-box-seam me-1"></i>
                                            {{ produit.quantite }} en stock
                                        </span>
                                    </div>

                                    <div class="mt-3">
                                        <a href="{{ path('ajouter_commande', {'produit_id': produit.id}) }}" 
                                           class="btn custom-btn w-100">
                                            <i class="bi-cart-plus me-2"></i>
                                            Commander
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>

        <section class="contact-section section-padding" id="contact">
            <div class="container">
                <div class="row">
                    <div class="col-12">
                        <div class="section-title-wrap mb-5">
                            <h2 class="text-white">Contactez-nous</h2>
                        </div>
                    </div>

                    <div class="col-lg-6 col-12">
                        <div class="custom-block custom-block-bg">
                            <h5 class="text-white mb-3">Informations de contact</h5>
                            <p class="text-white mb-2">
                                <i class="bi-geo-alt me-2"></i>
                                123 Rue de la Boutique, Tunis
                            </p>
                            <p class="text-white mb-2">
                                <i class="bi-telephone me-2"></i>
                                +216 12 345 678
                            </p>
                            <p class="text-white">
                                <i class="bi-envelope me-2"></i>
                                contact@eventuras.com
                            </p>
                        </div>
                    </div>

                    <div class="col-lg-6 col-12">
                        <div class="custom-block custom-block-bg">
                            <h5 class="text-white mb-3">Horaires d'ouverture</h5>
                            <p class="text-white mb-2">
                                <i class="bi-clock me-2"></i>
                                Lundi - Vendredi: 9h - 18h
                            </p>
                            <p class="text-white mb-2">
                                <i class="bi-clock me-2"></i>
                                Samedi: 9h - 13h
                            </p>
                            <p class="text-white">
                                <i class="bi-clock me-2"></i>
                                Dimanche: Fermé
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .custom-block-image-wrap {
            position: relative;
            width: 100%;
            height: 200px;
            overflow: hidden;
            border-radius: 8px 8px 0 0;
        }

        .custom-block-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s ease;
        }

        .custom-block:hover .custom-block-image {
            transform: scale(1.1);
        }

        .custom-block-info {
            padding: 20px;
        }

        .custom-btn {
            background-color: #4CAF50;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 5px;
            transition: background-color 0.3s ease;
        }

        .custom-btn:hover {
            background-color: #45a049;
            color: white;
        }

        .section-padding {
            padding: 100px 0;
        }

        .boutique-section {
            background-color: #1a1a1a;
        }

        .contact-section {
            background-color: #2a2a2a;
        }
    </style>
{% endblock %} 